from typing import Any, Dict
from saida_gerada.infra.dados.dao.dao_base import DAOBase
from saida_gerada.dominio_banco.entidades.{{ nome_tabela | lower }} import {{ nome_classe }}

class {{ nome_classe }}Dao(DAOBase[{{ nome_classe }}]):
    """
    DAO gerado automaticamente para a tabela '{{ nome_tabela }}'.
    Implementa os métodos abstratos exigidos pelo DAOBase do Trabalho 1.
    """

    @property
    def _nome_tabela(self) -> str:
        """Retorna o nome da tabela no banco de dados."""
        return "{{ nome_tabela }}"

    @property
    def _chave_primaria(self) -> str:
        """Retorna o nome da coluna de chave primária."""
        {%- for col in colunas if col.is_pk %}
        return "{{ col.nome }}"
        {%- else %}
        return "id"  # Fallback
        {%- endfor %}

    def _mapear_linha_para_objeto(self, linha: Any) -> {{ nome_classe }}:
        """Converte uma tupla (linha do banco) em uma instância da entidade."""
        return {{ nome_classe }}(*linha)

    def _extrair_dicionario(self, objeto: {{ nome_classe }}) -> Dict[str, Any]:
        """Converte a entidade em um dicionário para o DAOBase montar o SQL."""
        return {
            {%- for col in colunas %}
            "{{ col.nome }}": getattr(objeto, "{{ col.nome }}"){% if not loop.last %},{% endif %}
            {%- endfor %}
        }