def gerar_string_aleatoria(tamanho=10):
    return ''.join(random.choices(string.ascii_letters, k=tamanho))

def buscar_id_valido(nome_tabela_fk, coluna_pk_fk):
    """
    Busca um ID válido na tabela pai para usar como chave estrangeira.
    Retorna None se a tabela estiver vazia.
    """
    from saida_gerada.infra.dados.armazenamento.gerenciador_db import GerenciadorDB
    db = GerenciadorDB()
    try:
        conn = db._conexao  # Acessa a conexão já estabelecida
        cursor = conn.cursor()
        cursor.execute(f"SELECT {coluna_pk_fk} FROM {nome_tabela_fk} ORDER BY {coluna_pk_fk} LIMIT 1")
        resultado = cursor.fetchone()
        return resultado[0] if resultado else None
    except Exception:
        return None

